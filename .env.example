# =============================================================================
# A CASA DOS 20 — Variáveis de Ambiente Necessárias
# =============================================================================
# INSTRUÇÕES:
# 1. Copia este ficheiro para ".env" (nunca o commites para o Git)
# 2. Preenche os valores reais
# 3. No Replit, adiciona cada variável em Tools → Secrets
# =============================================================================

# --- BASE DE DADOS -----------------------------------------------------------
# Ligação à base de dados Neon PostgreSQL
# Formato: postgresql://user:password@host/dbname?sslmode=require
NEON_DATABASE_URL=postgresql://...

# --- AUTENTICAÇÃO GOOGLE -----------------------------------------------------
# Obtém em: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: https://SEU_DOMINIO/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Chave API do Google (para funcionalidades adicionais do Google)
GOOGLE_API_KEY=

# Segredo para assinar as sessões de utilizador (qualquer string longa aleatória)
# Gera um com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- NOTIFICAÇÕES PUSH (VAPID) -----------------------------------------------
# Gera um novo par com: npx web-push generate-vapid-keys
# IMPORTANTE: a chave pública tem de coincidir com a registada nos browsers dos utilizadores.
# Se alterares o par, os utilizadores perdem as subscrições até voltarem a aceitar.
VAPID_SUBJECT=mailto:quinzinhooliveiraa@gmail.com
VAPID_PUBLIC_KEY=BFWf1qCLJrnOiDrZZLmAeQHnAedp_ycyifaCZogdcyk_-aqx_J-c11XzQQpa8NcAb_TerKj-Zy3-QHFfXH8nBmk
VAPID_PRIVATE_KEY=

# --- STRIPE (PAGAMENTOS) -----------------------------------------------------
# Obtém em: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- EMAIL (BREVO) -----------------------------------------------------------
# Obtém em: https://app.brevo.com → Account → SMTP & API → API Keys
BREVO_API_KEY=

# --- VARIÁVEIS GERIDAS AUTOMATICAMENTE PELO REPLIT ---------------------------
# (Não precisas de definir estas — o Replit configura-as sozinho)
# REPLIT_DOMAINS=
# PORT=5000
# NODE_ENV=development
